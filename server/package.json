{
  "name": "server",
  "version": "1.0.0",
  "description": "iRtNexus backend server",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate-old": "tsx src/migrate.ts",
    "seed-old": "tsx src/seed.ts",
    "migrate": "tsx scripts/database/postgresql/migrate.ts",
    "seed": "tsx scripts/database/postgresql/seed.ts",
    "setup": "pnpm migrate && pnpm seed",
    "test": "tsx tests/unit/index.js"
  },
  "keywords": [
    "iRtNexus",
    "backend",
    "fastify",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.12.4",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/secure-session": "^8.3.0",
    "@fastify/swagger": "^9.7.0",
    "@itsrighttime/broadcast": "^0.0.8",
    "@itsrighttime/socket-io": "^0.0.5",
    "@itsrighttime/utils": "^0.0.21",
    "argon2": "^0.44.0",
    "bullmq": "^5.70.4",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "i18next": "^25.8.14",
    "i18next-fs-backend": "^2.6.1",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "neo4j-driver": "^6.0.1",
    "node-cache": "^5.1.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3"
  },
  "imports": {
    "#apps/*": [
      "apps/*"
    ],
    "#modules/*": [
      "modules/*"
    ],
    "#packages/*": [
      "packages/*"
    ],
    "#auth/*": [
      "packages/auth/*"
    ],
    "#database/*": [
      "packages/database/*"
    ],
    "#rbac/*": [
      "packages/rbac/*"
    ],
    "#tenant/*": [
      "packages/tenant/*"
    ],
    "#event-bus/*": [
      "packages/event-bus/*"
    ],
    "#logger/*": [
      "packages/logger/*"
    ],
    "#cache/*": [
      "packages/cache/*"
    ],
    "#queue/*": [
      "packages/queue/*"
    ],
    "#projects/*": [
      "modules/projects/*"
    ],
    "#hr/*": [
      "modules/hr/*"
    ],
    "#payroll/*": [
      "modules/payroll/*"
    ],
    "#partner/*": [
      "modules/partner/*"
    ],
    "#legal/*": [
      "modules/legal/*"
    ],
    "#configs/*": [
      "configs/*"
    ],
    "#tools/*": [
      "tools/*"
    ],
    "#utils": [
      "packages/utils/index.ts"
    ],
    "#libs": [
      "libs/index.ts"
    ],
    "#configs": [
      "configs/index.ts"
    ]
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
