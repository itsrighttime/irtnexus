{
  "name": "server",
  "version": "1.0.0",
  "description": "iRtNexus backend server",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "ts-node src/migrate.ts",
    "seed": "ts-node src/seed.ts",
    "setup": "pnpm migrate && pnpm seed"
  },
  "keywords": [
    "iRtNexus",
    "backend",
    "fastify",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.12.4",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/secure-session": "^8.3.0",
    "@fastify/swagger": "^9.7.0",
    "@itsrighttime/broadcast": "^0.0.8",
    "@itsrighttime/socket-io": "^0.0.5",
    "@itsrighttime/utils": "^0.0.21",
    "argon2": "^0.44.0",
    "bullmq": "^5.70.4",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "i18next": "^25.8.14",
    "i18next-fs-backend": "^2.6.1",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "neo4j-driver": "^6.0.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3"
  },
  "imports": {
    "#config": [
      "./src/config/index.ts"
    ],
    "#controllers": [
      "./src/controllers/index.ts"
    ],
    "#database": [
      "./src/database/index.ts"
    ],
    "#core": [
      "./src/core/index.ts"
    ],
    "#middlewares": [
      "./src/middlewares/index.ts"
    ],
    "#packages": [
      "./src/packages/index.ts"
    ],
    "#queries": [
      "./src/queries/index.ts"
    ],
    "#routes": [
      "./src/routes/index.ts"
    ],
    "#services": [
      "./src/services/index.ts"
    ],
    "#sessions": [
      "./src/sessions/index.ts"
    ],
    "#translations": [
      "./src/translations/index.ts"
    ],
    "#types": [
      "./src/types/index.ts"
    ],
    "#utils": [
      "./src/utils/index.ts"
    ],
    "#validations": [
      "./src/validations/index.ts"
    ],
    "#config/*": [
      "./src/config/*"
    ],
    "#controllers/*": [
      "./src/controllers/*"
    ],
    "#database/*": [
      "./src/database/*"
    ],
    "#core/*": [
      "./src/core/*"
    ],
    "#middlewares/*": [
      "./src/middlewares/*"
    ],
    "#packages/*": [
      "./src/packages/*"
    ],
    "#queries/*": [
      "./src/queries/*"
    ],
    "#routes/*": [
      "./src/routes/*"
    ],
    "#services/*": [
      "./src/services/*"
    ],
    "#sessions/*": [
      "./src/sessions/*"
    ],
    "#translations/*": [
      "./src/translations/*"
    ],
    "#types/*": [
      "./src/types/*"
    ],
    "#utils/*": [
      "./src/utils/*"
    ],
    "#validations/*": [
      "./src/validations/*"
    ]
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}