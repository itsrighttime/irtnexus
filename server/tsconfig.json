{
  "compilerOptions": {
    /* JavaScript / TypeScript Target */
    "target": "ES2020", // modern JS features
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowJs": false, // JS no longer needed
    "strict": true, // enable all strict type checks
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist", // compiled JS output
    "baseUrl": ".",

    /* Path Aliases */
    "paths": {
      "#apps/*": ["apps/*"],
      "#modules/*": ["modules/*"],
      "#packages/*": ["packages/*"],

      "#auth/*": ["packages/auth/*"],
      "#database/*": ["packages/database/*"],
      "#rbac/*": ["packages/rbac/*"],
      "#tenant/*": ["packages/tenant/*"],
      "#event-bus/*": ["packages/event-bus/*"],
      "#logger/*": ["packages/logger/*"],
      "#cache/*": ["packages/cache/*"],
      "#queue/*": ["packages/queue/*"],

      "#projects/*": ["modules/projects/*"],
      "#hr/*": ["modules/hr/*"],
      "#payroll/*": ["modules/payroll/*"],
      "#partner/*": ["modules/partner/*"],
      "#legal/*": ["modules/legal/*"],

      "#configs/*": ["configs/*"],
      "#tools/*": ["tools/*"],
      "#utils": ["packages/utils/index.ts"],
      "#libs": ["libs/index.ts"],
      "#configs": ["configs/index.ts"]
    }
  },
  "include": ["apps", "modules", "packages", "configs", "tools", "tests"],
  "exclude": ["node_modules", "dist"]
}
